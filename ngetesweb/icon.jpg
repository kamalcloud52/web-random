<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400" width="400" height="400">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#047857"/>
      <stop offset="100%" stop-color="#064e3b"/>
    </linearGradient>
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#fef08a"/>
      <stop offset="100%" stop-color="#fcd34d"/>
    </linearGradient>
    <filter id="shadow" x="-10%" y="-10%" width="120%" height="120%">
      <feDropShadow dx="0" dy="8" stdDeviation="6" flood-color="#000" flood-opacity="0.25"/>
    </filter>
  </defs>
  
  <!-- Outer circle background -->
  <circle cx="200" cy="200" r="190" fill="url(#bgGrad)" stroke="#fcd34d" stroke-width="8"/>
  
  <!-- Inner ring -->
  <circle cx="200" cy="200" r="170" fill="none" stroke="#ffffff" stroke-width="2" stroke-dasharray="8 6" opacity="0.4"/>
  
  <g filter="url(#shadow)">
    <!-- Open book symbol -->
    <!-- Left page -->
    <path d="M 200 230 C 160 210, 100 215, 80 235 L 80 145 C 100 125, 160 120, 200 140 Z" fill="#ffffff"/>
    <!-- Right page -->
    <path d="M 200 230 C 240 210, 300 215, 320 235 L 320 145 C 300 125, 240 120, 200 140 Z" fill="#f8fafc"/>
    <!-- Spine line -->
    <path d="M 200 140 L 200 230" stroke="#047857" stroke-width="3" stroke-linecap="round"/>
    
    <!-- Torch / Emblem above book -->
    <path d="M 190 125 L 210 125 L 205 145 L 195 145 Z" fill="url(#goldGrad)"/>
    <!-- Flame -->
    <path d="M 200 85 C 215 100, 215 115, 200 125 C 185 115, 185 100, 200 85 Z" fill="#ef4444"/>
    <path d="M 200 95 C 208 105, 208 112, 200 120 C 192 112, 192 105, 200 95 Z" fill="url(#goldGrad)"/>
  </g>
  
  <!-- Text PIM -->
  <text x="200" y="295" font-family="'Poppins', 'Segoe UI', sans-serif" font-weight="800" font-size="38" fill="url(#goldGrad)" text-anchor="middle" letter-spacing="4">PIM</text>
  <text x="200" y="325" font-family="'Poppins', 'Segoe UI', sans-serif" font-weight="500" font-size="14" fill="#ffffff" text-anchor="middle" letter-spacing="2">PERPUSTAKAAN DIGITAL</text>
</svg>
