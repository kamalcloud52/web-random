{
  "entities": {
    "User": {
      "title": "User",
      "description": "Basic user information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "photo": { "type": "string" },
        "location": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "worker"] }
      },
      "required": ["name", "role"]
    },
    "Worker": {
      "title": "Worker",
      "description": "Worker specific details.",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "verified": { "type": "boolean" },
        "rating": { "type": "number" },
        "activeStatus": { "type": "string" },
        "workArea": { "type": "string" },
        "whatsapp": { "type": "string" }
      },
      "required": ["category", "description", "whatsapp"]
    },
    "Portfolio": {
      "title": "Portfolio",
      "description": "Worker portfolio items.",
      "type": "object",
      "properties": {
        "workerId": { "type": "string" },
        "image": { "type": "string" },
        "caption": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workerId", "image", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Worker reviews.",
      "type": "object",
      "properties": {
        "workerId": { "type": "string" },
        "username": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" }
      },
      "required": ["workerId", "username", "rating"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of users."
    },
    "workers/{workerId}": {
      "schema": "Worker",
      "description": "Collection of workers."
    },
    "portfolios/{portfolioId}": {
      "schema": "Portfolio",
      "description": "Collection of portfolio posts."
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of reviews."
    }
  }
}
